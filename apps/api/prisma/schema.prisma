// The Language of the Quran — Prisma Schema
// Conventions: UUID PKs, timestamptz everywhere, deleted_at soft-delete on user tables

generator client {
  provider = "prisma-client"
  output   = "../../../libs/db/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum WordType {
  ISM
  FIL
  HARF
}

enum Gender {
  MASCULINE
  FEMININE
}

enum WordNumber {
  SINGULAR
  DUAL
  PLURAL
}

enum GramCase {
  MARFU
  MANSOOB
  MAJROOR
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ─── Corpus Tables (seeded once from libs/quran-data/) ───────────────────────

model QuranSurah {
  id          String       @id @default(uuid())
  number      Int          @unique
  nameArabic  String
  nameEnglish String
  verses      QuranVerse[]

  @@map("quran_surahs")
}

model QuranVerse {
  id          String      @id @default(uuid())
  surah       QuranSurah  @relation(fields: [surahId], references: [id])
  surahId     String
  ayahNumber  Int
  arabicText  String      // Uthmani script
  translation String      // English (Sahih International default)
  verseWords  VerseWord[]

  @@unique([surahId, ayahNumber])
  @@map("quran_verses")
}

model Root {
  id              String  @id @default(uuid())
  arabic          String  @unique // "ر ح م"
  transliteration String
  primaryMeaning  String
  words           Word[]

  @@map("roots")
}

model Word {
  id              String           @id @default(uuid())
  root            Root?            @relation(fields: [rootId], references: [id])
  rootId          String?
  arabic          String
  transliteration String
  meaning         String
  wordType        WordType
  gender          Gender?
  number          WordNumber?
  grammaticalCase GramCase?
  frequencyRank   Int?
  verseWords      VerseWord[]
  reviews         UserWordReview[]
  deletedAt       DateTime?

  @@map("words")
}

model VerseWord {
  id              String     @id @default(uuid())
  verse           QuranVerse @relation(fields: [verseId], references: [id])
  verseId         String
  word            Word       @relation(fields: [wordId], references: [id])
  wordId          String
  position        Int
  grammaticalRole String

  @@map("verse_words")
}

// ─── Curriculum Tables ───────────────────────────────────────────────────────

model ContentVersion {
  id          String   @id @default(uuid())
  versionHash String   @unique
  cdnUrl      String
  publishedAt DateTime @default(now()) @db.Timestamptz
  isActive    Boolean  @default(false)

  @@map("content_versions")
}

model Level {
  id          String  @id @default(uuid())
  number      Int     @unique
  title       String
  description String
  tagline     String  @default("")
  icon        String  @default("")
  milestone   Json?   // { badge, badgeIcon, message, surahUnlock?, unlocksLevel }
  units       Unit[]

  @@map("levels")
}

model Unit {
  id         String   @id @default(uuid())
  level      Level    @relation(fields: [levelId], references: [id])
  levelId    String
  number     Int
  title      String
  tagline    String   @default("")
  xpBonus    Int      @default(0)
  badge      Json?    // { title, icon }
  unlockedBy String?  // unit ID or "level-N" string
  lessons    Lesson[]

  @@map("units")
}

model Lesson {
  id               String               @id @default(uuid())
  unit             Unit                 @relation(fields: [unitId], references: [id])
  unitId           String
  number           Int
  title            String
  xpReward         Int                  @default(10)
  contentHash      String
  exercises        Json
  version          Int                  @default(1)
  isPublished      Boolean              @default(false)
  lessonType       String               @default("concept") // concept|grammar|vocabulary|application|review
  estimatedMinutes Int                  @default(10)
  unlockedBy       String?              // lesson ID or unit ID string
  progress         UserLessonProgress[]
  deletedAt        DateTime?

  @@map("lessons")
}

model XpTier {
  id         String @id @default(uuid())
  level      Int    @unique // 1–6
  title      String         // "Seeker", "Reader", etc.
  xpRequired Int            // XP threshold to reach this tier

  @@map("xp_tiers")
}

// ─── User Tables ─────────────────────────────────────────────────────────────

model AppUser {
  id                    String               @id @default(uuid())
  clerkId               String               @unique
  timezone              String               @default("UTC")
  onboardingCompletedAt DateTime?            @db.Timestamptz
  lastActiveAt          DateTime?            @db.Timestamptz
  createdAt             DateTime             @default(now()) @db.Timestamptz
  updatedAt             DateTime             @updatedAt @db.Timestamptz
  deletedAt             DateTime?            @db.Timestamptz
  streak                UserStreak?
  lessonProgress        UserLessonProgress[]
  badges                UserBadge[]
  wordReviews           UserWordReview[]
  reviewSessions        ReviewSession[]
  pushTokens            UserPushToken[]

  @@map("app_users")
}

// ─── Gamification Tables ─────────────────────────────────────────────────────

model UserStreak {
  id               String    @id @default(uuid())
  user             AppUser   @relation(fields: [userId], references: [id])
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  totalXp          Int       @default(0)
  lastActivityDate DateTime? // DATE in user's timezone — not timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  @@map("user_streaks")
}

model UserLessonProgress {
  id                String         @id @default(uuid())
  user              AppUser        @relation(fields: [userId], references: [id])
  userId            String
  lesson            Lesson         @relation(fields: [lessonId], references: [id])
  lessonId          String
  status            ProgressStatus @default(NOT_STARTED)
  xpEarned          Int            @default(0)
  attemptsTotal     Int            @default(0)
  firstAttemptScore Int?
  timeSpentMs       BigInt         @default(0)
  lessonVersion     Int            @default(1)
  firstStartedAt    DateTime?      @db.Timestamptz
  lastAttemptedAt   DateTime?      @db.Timestamptz
  completedAt       DateTime?      @db.Timestamptz
  deletedAt         DateTime?      @db.Timestamptz

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  iconSlug    String
  condition   Json        // { type: "streak", threshold: 7 }
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  user     AppUser  @relation(fields: [userId], references: [id])
  userId   String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  badgeId  String
  earnedAt DateTime @default(now()) @db.Timestamptz

  @@id([userId, badgeId])
  @@map("user_badges")
}

// ─── SRS Tables (SM-2) ───────────────────────────────────────────────────────

model UserWordReview {
  id             String      @id @default(uuid())
  user           AppUser     @relation(fields: [userId], references: [id])
  userId         String
  word           Word        @relation(fields: [wordId], references: [id])
  wordId         String
  itemType       String      // "word" | "root" | "verse_fragment"
  easinessFactor Decimal     @default(2.5) // SM-2 EF, floor 1.3
  intervalDays   Int         @default(1)
  repetitions    Int         @default(0)
  nextReviewAt   DateTime    @db.Timestamptz
  lastReviewedAt DateTime?   @db.Timestamptz
  lastQuality    Int?        // 0–5
  totalReviews   Int         @default(0)
  totalCorrect   Int         @default(0)
  createdAt      DateTime    @default(now()) @db.Timestamptz
  updatedAt      DateTime    @updatedAt @db.Timestamptz
  reviewLogs     ReviewLog[]

  @@unique([userId, wordId])
  @@map("user_word_reviews")
}

model ReviewLog {
  id             String         @id @default(uuid())
  review         UserWordReview @relation(fields: [reviewId], references: [id])
  reviewId       String
  userId         String
  quality        Int            // 0–5
  responseTimeMs Int?
  intervalBefore Int
  intervalAfter  Int
  efBefore       Decimal
  efAfter        Decimal
  lessonId       String?
  sessionId      String?
  reviewedAt     DateTime       @default(now()) @db.Timestamptz

  @@map("review_logs")
}

model ReviewSession {
  id            String    @id @default(uuid())
  user          AppUser   @relation(fields: [userId], references: [id])
  userId        String
  startedAt     DateTime  @default(now()) @db.Timestamptz
  completedAt   DateTime? @db.Timestamptz
  itemsReviewed Int       @default(0)
  itemsCorrect  Int       @default(0)

  @@map("review_sessions")
}

// ─── Infrastructure Tables ───────────────────────────────────────────────────

model FeatureFlag {
  key         String   @id
  value       Json
  description String
  enabledFor  String[] // user IDs for targeted rollout
  rolloutPct  Int      @default(100)
  createdAt   DateTime @default(now()) @db.Timestamptz

  @@map("feature_flags")
}

model UserPushToken {
  id         String    @id @default(uuid())
  user       AppUser   @relation(fields: [userId], references: [id])
  userId     String
  token      String    @unique
  platform   String    // "ios" | "android" | "web"
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now()) @db.Timestamptz
  lastUsedAt DateTime? @db.Timestamptz

  @@map("user_push_tokens")
}

model ContentFeedback {
  id           String   @id @default(uuid())
  userId       String?
  itemType     String   // "exercise" | "translation" | "word"
  itemId       String
  feedbackType String   // "error" | "confusing" | "suggestion"
  body         String
  status       String   @default("open")
  createdAt    DateTime @default(now()) @db.Timestamptz

  @@map("content_feedback")
}
