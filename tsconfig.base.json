{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
    "customConditions": ["@org/source"],
    "paths": {
      "@org/api-types": ["libs/api-types/src/index.ts"],
      "@org/srs": ["libs/srs/src/index.ts"],
      "@org/db": ["libs/db/src/index.ts"],
      "@org/quran-data": ["libs/quran-data/src/index.ts"],
      "@org/content": ["libs/content/src/index.ts"]
    }
  }
}
